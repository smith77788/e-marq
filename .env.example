# Core Supabase configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vite client-side fallbacks
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-anon-key
VITE_PUBLIC_APP_URL=https://app.example.com

# Public app URLs
APP_BASE_URL=https://app.example.com
PUBLIC_APP_URL=https://app.example.com

# Cron and internal automation auth
CRON_SECRET=replace-with-a-long-random-secret
CRON_ALLOW_ANON=false

# AI and platform connectors
LOVABLE_API_KEY=
ACOS_AI_ENABLED=true
ACOS_AI_DISABLED=false

# Email delivery
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_WEBHOOK_INSECURE=0

# Telegram bot + MTProto bridge
TELEGRAM_API_KEY=
TG_MTPROTO_BRIDGE_URL=
TG_MTPROTO_BRIDGE_SECRET=
TG_SESSION_ENC_KEY=

# Shipping / logistics
NOVA_POSHTA_API_KEY=

# Outreach / social connectors
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=marq-outreach/1.0
INSTAGRAM_RSS_URL=
