function deduplicateRecommendations(recs: Recommendation[]): Recommendation[] {
  const seen = new Set<string>();
  return recs.filter((r) => {
    if (seen.has(r.product_id)) return false;
    seen.add(r.product_id);
    return true;
  }).sort((a, b) => b.score - a.score);
}
