  // Дні до оновлення
  const periodEnd = new Date(sub.current_period_end);
  const daysUntilRenewal = Math.max(0, Math.ceil((periodEnd.getTime() - Date.now()) / (24 * 3600 * 1000)));

  // Рекомендація
  let recommendation = "Поточний тариф підходить";
  if (usagePct > 90) {
