  phone: (message = "Некоректний телефон"): ValidationRule => ({ type: "phone", message }),
  uuid: (message = "Некоректний ID"): ValidationRule => ({ type: "uuid", message }),
  min: (min: number, message?: string): ValidationRule => ({
