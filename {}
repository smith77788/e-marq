export type NotificationType =
  | "revenue_alert"
  | "stock_alert"
  | "churn_risk"
  | "opportunity"
  | "agent_insight";

export type NotificationSeverity = "critical" | "high" | "medium" | "low";

export type Notification = {
  id: string;
  tenant_id: string;
  type: NotificationType;
  severity: NotificationSeverity;
  title: string;
  body: string;
  action_url?: string;
  action_label?: string;
